# Server
PORT=4001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
FRONTEND_DIST_DIR=
## If Vite picks a different port (e.g., 5174), use a comma-separated allowlist:
## CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:55433/scpd_cms?schema=public

# Auth
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800
GOOGLE_CLIENT_ID=
LOGIN_OTP_TTL_SECONDS=900
LOGIN_OTP_LENGTH=6
LOGIN_OTP_MAX_ATTEMPTS=5

# Security
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=600

# Notifications (case-management-system backend only)
# Option A: webhook relay endpoints
EMAIL_NOTIFICATION_WEBHOOK_URL=
SMS_NOTIFICATION_WEBHOOK_URL=
NOTIFICATION_WEBHOOK_TIMEOUT_MS=10000

# Option B: direct SMTP email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_REQUIRE_TLS=false
EMAIL_OTP_CONTENT=Dear Citizen, {OTP} is your One Time Password (OTP) for login to the SCPD Portal. This OTP is confidential and valid for 15 minutes. You are advised not to share it with anyone. If you have not requested this OTP, please ignore this email. For any assistance, you may contact: Phone: 0674-2954518 Regards, State Commissioner for Persons with Disabilities (SCPD) Government of Odisha
EMAIL_REGISTRATION_CONTENT=Dear Citizen, Greetings from the State Commissioner for Persons with Disabilities (SCPD), Government of Odisha. This is to inform you that your registration on the SCPD Portal has been successfully completed. You may now log in to the portal using your registered credentials to access the services available. You are advised to keep your login credentials confidential and not share them with any unauthorized person. If you have not performed this registration, you are requested to contact the office immediately. For any assistance, you may contact: Phone: 0674-2954518 Regards, State Commissioner for Persons with Disabilities (SCPD) Government of Odisha.
EMAIL_COMPLAINT_CONTENT=Dear Citizen, Greetings from the State Commissioner for Persons with Disabilities (SCPD), Government of Odisha. This is to acknowledge that your grievance has been successfully received on the SCPD Portal. The concerned authority will examine your submission and take necessary action per the applicable procedures. You will be informed of further updates in due course. as If you have not submitted this grievance, you are advised to contact the office immediately. For any assistance, you may contact: Phone: 0674-2954518 Regards, State Commissioner for Persons with Disabilities (SCPD) Government of Odisha.

# Option C: Odisha Govt SMS gateway (direct)
GOVT_SMS_API_URL=https://govtsms.odisha.gov.in/api/api.php
GOVT_SMS_SOURCE=ODIGOV
GOVT_SMS_FORCE_SOURCE=
GOVT_SMS_SOURCE_FALLBACKS=
GOVT_SMS_DEPARTMENT_ID=D056002
GOVT_SMS_TEMPLATE_ID=
GOVT_SMS_OTP_TEMPLATE_ID=1007556907987287759
GOVT_SMS_REGISTRATION_TEMPLATE_ID=1007658595469878380
GOVT_SMS_COMPLAINT_TEMPLATE_ID=1007977038878676392
GOVT_SMS_DEFAULT_ACTION=singleSMS
GOVT_SMS_OTP_ACTION=sendOTPSMS
GOVT_SMS_REGISTRATION_ACTION=singleSMS
GOVT_SMS_COMPLAINT_ACTION=singleSMS
GOVT_SMS_OTP_SEND_BOTH_ACTIONS=false
GOVT_SMS_COUNTRY_CODE=91
GOVT_SMS_FORCE_COUNTRY_CODE=false
GOVT_SMS_STRIP_COUNTRY_CODE=true
SMS_DELIVERY_DEBUG_LOG=false
GOVT_SMS_OTP_CONTENT=SCPD, Govt. of Odisha: {#var#} is your OTP for login to SCPD Portal. Valid for 15 minutes only. Do not disclose it to anyone. For assistance call 0674-2954518.
GOVT_SMS_REGISTRATION_CONTENT=SCPD, Govt. of Odisha: Your registration on the SCPD Portal has been completed successfully. You may now login using your registered credentials to access services. For assistance call 0674-2954518.
GOVT_SMS_COMPLAINT_CONTENT=SCPD, Govt. of Odisha: Your complaint has been successfully submitted on SCPD Portal. It will be reviewed and necessary action will be taken. For assistance call 0674-2954518.
